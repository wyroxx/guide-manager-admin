rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function hasEmail() {
      return isSignedIn() && userEmail() is string && userEmail().size() > 0;
    }

    function isAdmin() {
      return isSignedIn()
        && 'admin' in request.auth.token
        && request.auth.token.admin == true;
    }

    function guidePath() {
      return /databases/$(database)/documents/guides/$(request.auth.uid);
    }

    function guidePathByUid(uid) {
      return /databases/$(database)/documents/guides/$(uid);
    }

    function isGuideLevel(level) {
      return level in ['trainee', 'junior', 'middle', 'senior'];
    }

    function isApprovedGuide() {
      return hasEmail()
        && exists(guidePath())
        && get(guidePath()).data.email == userEmail()
        && get(guidePath()).data.isApproved == true
        && isGuideLevel(get(guidePath()).data.level);
    }

    function validGuideRequestCreate(guideId) {
      return hasEmail()
        && guideId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'avatar',
          'bio',
          'createdAt',
          'email',
          'isApproved',
          'level',
          'name',
          'phone',
          'telegramAlias',
          'toursCount',
          'uid',
          'updatedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == userEmail()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.isApproved == false
        && request.resource.data.level == ''
        && request.resource.data.phone == ''
        && request.resource.data.toursCount == 0
        && request.resource.data.avatar == ''
        && request.resource.data.bio == ''
        && request.resource.data.telegramAlias == ''
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validExcursionData(data) {
      let companyPath = /databases/$(database)/documents/companies/$(data.companyId);

      return data.title is string
        && data.title.size() > 0
        && data.companyId is string
        && exists(companyPath)
        && data.companyName == get(companyPath).data.name
        && data.startDate is timestamp
        && data.endDate is timestamp
        && data.endDate > data.startDate
        && data.route is string
        && data.meetingPlace is string
        && data.requiredGuides is int
        && data.requiredGuides > 0
        && data.requiredLevels is list
        && data.requiredLevels.size() > 0
        && data.requiredLevels.hasOnly(['trainee', 'junior', 'middle', 'senior'])
        && data.maxParticipants is int
        && data.maxParticipants > 0
        && data.hasLunch is bool
        && data.hasMasterclass is bool
        && data.excursionType is string
        && data.paymentStatus in ['paid', 'unpaid']
        && data.assignedGuides is list
        && data.hasSpots == (data.assignedGuides.size() < data.requiredGuides);
    }

    function hasOwnApplication(excursionId) {
      return exists(
        /databases/$(database)/documents/excursions/$(excursionId)/applications/$(request.auth.uid)
      );
    }

    function canReadExcursion(excursionId) {
      return isApprovedGuide()
        && (
          userEmail() in resource.data.assignedGuides
          || (
            resource.data.hasSpots == true
            && resource.data.requiredLevels.hasAny([get(guidePath()).data.level])
          )
          || hasOwnApplication(excursionId)
        );
    }

    function companyAllowsGuide(companyId) {
      let companyPath = /databases/$(database)/documents/companies/$(companyId);
      return exists(companyPath)
        && !(userEmail() in get(companyPath).data.banList);
    }

    function validApplicationCreate(excursionId, applicationId) {
      let excursionPath = /databases/$(database)/documents/excursions/$(excursionId);
      let excursion = get(excursionPath).data;

      return isApprovedGuide()
        && exists(excursionPath)
        && applicationId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'createdAt',
          'excursionId',
          'excursionMaxParticipants',
          'excursionStartDate',
          'excursionTitle',
          'guideEmail',
          'guideName',
          'guideUid',
          'status'
        ])
        && request.resource.data.guideUid == request.auth.uid
        && request.resource.data.guideEmail == userEmail()
        && request.resource.data.guideName == get(guidePath()).data.name
        && request.resource.data.excursionId == excursionId
        && request.resource.data.excursionTitle == excursion.title
        && request.resource.data.excursionStartDate == excursion.startDate
        && request.resource.data.excursionMaxParticipants == excursion.maxParticipants
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && excursion.hasSpots == true
        && excursion.requiredLevels.hasAny([get(guidePath()).data.level])
        && !(userEmail() in excursion.assignedGuides)
        && companyAllowsGuide(excursion.companyId);
    }

    function validApplicationDecision(excursionId) {
      let excursionPath = /databases/$(database)/documents/excursions/$(excursionId);

      return isAdmin()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'rejected']
        && request.resource.data.guideUid == resource.data.guideUid
        && request.resource.data.guideEmail == resource.data.guideEmail
        && (
          (
            'guideName' in resource.data
            && request.resource.data.guideName == resource.data.guideName
          )
          || (
            !('guideName' in resource.data)
            && !('guideName' in request.resource.data)
          )
        )
        && request.resource.data.excursionId == resource.data.excursionId
        && request.resource.data.excursionTitle == resource.data.excursionTitle
        && request.resource.data.excursionStartDate == resource.data.excursionStartDate
        && request.resource.data.excursionMaxParticipants == resource.data.excursionMaxParticipants
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.decidedAt == request.time
        && request.resource.data.decidedBy == request.auth.uid
        && (
          !('decisionComment' in request.resource.data)
          || (
            request.resource.data.decisionComment is string
            && request.resource.data.decisionComment.size() <= 500
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'decidedAt',
          'decidedBy',
          'decisionComment'
        ])
        && (
          request.resource.data.status == 'rejected'
          || (
            request.resource.data.guideEmail in getAfter(excursionPath).data.assignedGuides
            && validExcursionData(getAfter(excursionPath).data)
          )
        );
    }

    match /guides/{guideId} {
      allow get: if isAdmin()
        || (isSignedIn() && guideId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isAdmin() || validGuideRequestCreate(guideId);
      allow update, delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow get: if isAdmin();
      allow list: if isAdmin()
        || (
          isApprovedGuide()
          && request.auth.token.email in resource.data.banList
        );
      allow create, update, delete: if isAdmin();
    }

    match /excursions/{excursionId} {
      allow read: if isAdmin() || canReadExcursion(excursionId);
      allow create, update: if isAdmin()
        && validExcursionData(request.resource.data);
      allow delete: if isAdmin();

      match /applications/{applicationId} {
        allow get: if isAdmin()
          || (isApprovedGuide() && applicationId == request.auth.uid);
        allow list: if isAdmin()
          || (isApprovedGuide() && resource.data.guideUid == request.auth.uid);
        allow create: if validApplicationCreate(excursionId, applicationId);
        allow update: if validApplicationDecision(excursionId);
        allow delete: if isAdmin();
      }
    }

    match /{path=**}/applications/{applicationId} {
      allow read: if isAdmin()
        || (isApprovedGuide() && resource.data.guideUid == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
